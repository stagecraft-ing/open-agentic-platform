{
  "name": "@opc/git-panel",
  "version": "0.1.0",
  "description": "Comprehensive git panel with plumbing-based status, staging, commits, branches, and AI commit messages",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./plumbing": "./src/backend/plumbing.ts",
    "./parser": "./src/backend/parser.ts",
    "./diff-parser": "./src/backend/diff-parser.ts",
    "./staging": "./src/operations/staging.ts",
    "./commit": "./src/operations/commit.ts",
    "./branch": "./src/operations/branch.ts",
    "./ai": "./src/ai/commit-message.ts",
    "./watcher": "./src/watcher.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "oap": {
    "spec": "059-git-panel"
  }
}
