{
  "name": "@opc/prompt-assembly",
  "version": "0.1.0",
  "description": "Modular system prompt assembly with cache boundaries and context compaction",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./assembler": "./src/assembler.ts",
    "./compaction": "./src/compaction.ts",
    "./defaults": "./src/defaults.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@opc/yaml-standards-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "oap": {
    "spec": "070-prompt-assembly-cache"
  }
}
