{
  "name": "@opc/panel-event-bus",
  "version": "0.1.0",
  "description": "Typed inter-panel event bus with contract enforcement, source auto-exclusion, wildcard subscriptions, and bounded event history",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./bus": "./src/event-bus.ts",
    "./contracts": "./src/contracts.ts",
    "./wildcards": "./src/wildcards.ts",
    "./lifecycle": "./src/lifecycle.ts",
    "./events": "./src/core-events.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/node": "^24.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
