# Hetzner Deployment Secrets
# Copy to .env and fill in real values before running post-create.sh

# --- Hetzner ---
HCLOUD_TOKEN=

# --- Let's Encrypt ---
LETSENCRYPT_EMAIL=admin@stagecraft.ing

# --- PostgreSQL (Bitnami in-cluster) ---
POSTGRES_PASSWORD=

# --- Rauthy OIDC (each must be >= 16 chars) ---
RAUTHY_RAFT_SECRET=
RAUTHY_API_SECRET=
RAUTHY_ADMIN_PASSWORD=

# --- Stagecraft Secrets ---
DOMAIN=stagecraft.ing
APP_BASE_URL=https://stagecraft.ing
SESSION_SECRET=
DB_PASSWORD=  # same as POSTGRES_PASSWORD

# --- OIDC Clients (create in Rauthy admin after deploying rauthy) ---
OIDC_SPA_CLIENT_ID=
OIDC_M2M_CLIENT_ID=
OIDC_M2M_CLIENT_SECRET=
RAUTHY_URL=https://auth.stagecraft.ing
RAUTHY_CLIENT_ID=
RAUTHY_CLIENT_SECRET=
RAUTHY_ADMIN_TOKEN=

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/developers
# Homepage URL: https://stagecraft.ing
# Callback URL: https://stagecraft.ing/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- GitHub App ---
# Create at: https://github.com/settings/apps
# Webhook URL: https://stagecraft.ing/api/github/webhook
# Permissions: Contents (read), Pull requests (read/write), Metadata (read)
# Events: Push, Pull request
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=  # base64-encoded .pem contents
GITHUB_WEBHOOK_SECRET=

# --- Optional ---
SLACK_WEBHOOK_URL=

# --- GHCR (for docker push) ---
GHCR_USERNAME=
GHCR_TOKEN=  # PAT with write:packages scope
