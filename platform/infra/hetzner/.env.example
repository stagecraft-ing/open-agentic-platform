# =============================================================================
# OAP Hetzner Deployment — Environment Configuration
# =============================================================================
# Copy to .env:  cp .env.example .env
# Then fill in HCLOUD_TOKEN and run:  ./setup.sh
#
# Secrets marked [auto] are generated automatically if left empty.
# Secrets marked [manual] require you to create them externally first.
# =============================================================================

# --- Required: Hetzner Cloud ---
HCLOUD_TOKEN=

# --- Required: Domain (change if using a different domain) ---
DOMAIN=<your-domain-name>
APP_BASE_URL=https://<your-domain-name>
LETSENCRYPT_EMAIL=admin@<your-domain-name>
RAUTHY_URL=https://auth.<your-domain-name>

# --- [auto] Generated on first run if empty ---
POSTGRES_PASSWORD=
SESSION_SECRET=
# --- Rauthy OIDC (each must be >= 16 chars) ---
RAUTHY_RAFT_SECRET=
RAUTHY_API_SECRET=
RAUTHY_ADMIN_PASSWORD=
RAUTHY_ENC_KEY_ID=
RAUTHY_ENC_KEY=
HIQLITE_SECRET_RAFT=
HIQLITE_SECRET_API=
GITHUB_WEBHOOK_SECRET=

# --- [manual] GitHub OAuth App ---
# Create at: https://github.com/settings/developers
#   Homepage URL:  https://<your-domain-name>
#   Callback URL:  https://<your-domain-name>/auth/v1/providers/callback
GITHUB_UPSTREAM_CLIENT_ID=
GITHUB_UPSTREAM_CLIENT_SECRET=

# --- [manual] GitHub App ---
# Create at: https://github.com/settings/apps/new
#   Webhook URL:   https://<your-domain-name>/api/github/webhook
#   Webhook secret: use the auto-generated GITHUB_WEBHOOK_SECRET above
#   Permissions:   Contents (read), Pull requests (read/write), Metadata (read)
#   Events:        Push, Pull request
GITHUB_APP_ID=
# Store as base64: base64 -w0 < private-key.pem  (Linux) or base64 -i private-key.pem (macOS)
GITHUB_APP_PRIVATE_KEY_B64=

# --- [manual] OIDC clients (created in Rauthy admin after Phase 1) ---
# Log into https://auth.<your-domain-name> after Phase 1 completes.
# Create SPA + M2M + server clients, then fill these in and re-run ./setup.sh
OIDC_SPA_CLIENT_ID=
OIDC_M2M_CLIENT_ID=
OIDC_M2M_CLIENT_SECRET=
RAUTHY_CLIENT_ID=
RAUTHY_CLIENT_SECRET=
RAUTHY_ADMIN_TOKEN=

# --- [manual] GHCR image pull (for pulling private container images) ---
# A GitHub PAT with read:packages scope, used for:
#   1. Creating K8s image-pull secrets so pods can pull from ghcr.io
#   2. Syncing to GitHub Actions secrets (if gh CLI is available)
GHCR_PAT=

# --- Optional ---
SLACK_WEBHOOK_URL=
