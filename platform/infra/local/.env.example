# Local development secrets
# Copy to .env and fill in real values

# Database URLs (use host.k3d.internal for k3d, host.docker.internal for kind)
STAGECRAFT_DB_URL=postgres://postgres:postgres@host.k3d.internal:5432/stagecraft
DEPLOYD_DB_URL=postgres://postgres:postgres@host.k3d.internal:5432/deployd

# Logto M2M credentials (use test values for local dev)
LOGTO_M2M_CLIENT_ID=local-dev-client-id
LOGTO_M2M_CLIENT_SECRET=local-dev-client-secret
