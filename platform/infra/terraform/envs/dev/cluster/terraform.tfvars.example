# Core platform hosts (DEV)
# ------------------------------------------------------------------------------

stagecraft_host = "stagecraft.localdev.online"
deployd_host    = "deployd.localdev.online"

logto_host       = "logto.localdev.online"
logto_admin_host = "logto-admin.localdev.online"

logto_postgres_password = "change-me"

letsencrypt_email = "admin@example.com"

# If true, Terraform applies the ClusterIssuer resource
apply_cluster_issuer = true

slack_webhook_url = "https://hooks.slack.com/services/"
# ------------------------------------------------------------------------------
# Logto Custom Setup - Non-sensitive
# ------------------------------------------------------------------------------

# Primary domain used by the application
domain = "localdev.online"

# App identity
app_name = "Stagecraft"
app_url  = "https://stagecraft.localdev.online"

# Logto application IDs (must remain stable)
logto_spa_client_id                          = "stagecraft-spa-app"
logto_m2m_client_id   = "stagecraft-m2m-app"

# Resource identifier used in access tokens
logto_spa_api_resource = "https://api.stagecraft.localdev.online"

# Webhook endpoint
logto_spa_api_event_webhook_url = "https://stagecraft.localdev.online/api/logto/webhook"

# Optional Google OAuth
logto_google_connector_id  = "google-universal"
logto_google_client_id     = "your-google-client-id"

# Optional Google Workspace SSO
logto_google_workspace_connector_id               = "google-workspace"
logto_google_workspace_client_id                  = "your-google-workspace-client-id"
logto_google_workspace_connector_approved_domains = "[\"example.com\"]"

# ------------------------------------------------------------------------------
# Logto Custom Setup - Sensitive (DO NOT COMMIT REAL VALUES)
# ------------------------------------------------------------------------------

logto_spa_client_secret = "change-me-app-secret"

logto_m2m_client_secret = "change-me-management-secret"

logto_spa_api_event_webhook_signing_key = "change-me-webhook-signing-key"

logto_google_client_secret = "change-me-google-client-secret"

logto_google_workspace_client_secret = "change-me-google-workspace-client-secret"
