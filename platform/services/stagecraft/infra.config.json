{
  "$schema": "https://encore.dev/schemas/infra.schema.json",
  "secrets": {
    "DOMAIN": { "$env": "DOMAIN" },
    "APP_BASE_URL": { "$env": "APP_BASE_URL" },
    "SESSION_SECRET": { "$env": "SESSION_SECRET" },
    "OIDC_SPA_CLIENT_ID": { "$env": "OIDC_SPA_CLIENT_ID" },
    "RAUTHY_URL": { "$env": "RAUTHY_URL" },
    "RAUTHY_CLIENT_ID": { "$env": "RAUTHY_CLIENT_ID" },
    "RAUTHY_CLIENT_SECRET": { "$env": "RAUTHY_CLIENT_SECRET" },
    "RAUTHY_ADMIN_TOKEN": { "$env": "RAUTHY_ADMIN_TOKEN" },
    "RAUTHY_ADMIN_TOKEN_NAME": { "$env": "RAUTHY_ADMIN_TOKEN_NAME" },
    "PAT_ENCRYPTION_KEY": { "$env": "PAT_ENCRYPTION_KEY" },
    "GITHUB_APP_ID": { "$env": "GITHUB_APP_ID" },
    "GITHUB_APP_PRIVATE_KEY": { "$env": "GITHUB_APP_PRIVATE_KEY" },
    "GITHUB_WEBHOOK_SECRET": { "$env": "GITHUB_WEBHOOK_SECRET" },
    "SLACK_WEBHOOK_URL": { "$env": "SLACK_WEBHOOK_URL" },
    "S3_ENDPOINT": { "$env": "S3_ENDPOINT" },
    "S3_REGION": { "$env": "S3_REGION" },
    "S3_ACCESS_KEY": { "$env": "S3_ACCESS_KEY" },
    "S3_SECRET_KEY": { "$env": "S3_SECRET_KEY" }
  },
  "pubsub": [
    {
      "type": "nsq",
      "hosts": "nsqd.stagecraft-system.svc.cluster.local:4150",
      "topics": {
        "uptime-transition": {
          "name": "uptime-transition",
          "subscriptions": {
            "slack-notification": {
              "name": "slack-notification"
            }
          }
        },
        "site.added": {
          "name": "site.added",
          "subscriptions": {
            "check-site": {
              "name": "check-site"
            }
          }
        },
        "factory-event": {
          "name": "factory-event",
          "subscriptions": {
            "slack-factory-notification": {
              "name": "slack-factory-notification"
            },
            "sync-relay": {
              "name": "sync-relay"
            }
          }
        }
      }
    }
  ],
  "sql_servers": [
    {
      "host": "postgresql.stagecraft-system.svc.cluster.local",
      "databases": {
        "auth": {
          "name": "auth",
          "username": "stagecraft",
          "password": {
            "$env": "POSTGRES_PASSWORD"
          }
        },
        "monitor": {
          "name": "monitor",
          "username": "stagecraft",
          "password": {
            "$env": "POSTGRES_PASSWORD"
          }
        },
        "site": {
          "name": "site",
          "username": "stagecraft",
          "password": {
            "$env": "POSTGRES_PASSWORD"
          }
        }
      }
    }
  ]
}
