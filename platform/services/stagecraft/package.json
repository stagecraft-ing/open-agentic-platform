    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
