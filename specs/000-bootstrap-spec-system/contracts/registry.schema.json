{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-agentic-platform.local/specs/000-bootstrap-spec-system/registry.schema.json",
  "title": "Open Agentic Platform — compiled spec registry (deterministic MVP)",
  "type": "object",
  "additionalProperties": false,
  "required": ["specVersion", "build", "features", "validation"],
  "properties": {
    "specVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compilerId", "compilerVersion", "inputRoot", "contentHash"],
      "properties": {
        "compilerId": { "type": "string", "minLength": 1 },
        "compilerVersion": { "type": "string", "minLength": 1 },
        "inputRoot": {
          "type": "string",
          "minLength": 1,
          "description": "Repository-relative root used for this compilation. Canonical full-repo value is \".\"; normalization rules: Feature 000 research D8 and Feature 001 spec."
        },
        "contentHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "features": {
      "type": "array",
      "items": { "$ref": "#/$defs/featureRecord" }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "violations"],
      "properties": {
        "passed": { "type": "boolean" },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/violation" }
        }
      }
    }
  },
  "$defs": {
    "featureRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "created", "summary", "specPath", "sectionHeadings"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9]{3}-[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "superseded", "retired"]
        },
        "created": { "type": "string", "format": "date" },
        "summary": { "type": "string", "minLength": 1 },
        "specPath": { "type": "string", "pattern": "^specs/[0-9]{3}-[^/]+/spec\\.md$" },
        "sectionHeadings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "authors": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "kind": { "type": "string" },
        "featureBranch": { "type": "string" },
        "extraFrontmatter": {
          "type": "object",
          "maxProperties": 8,
          "additionalProperties": { "$ref": "#/$defs/extraFrontmatterValue" }
        },
        "codeAliases": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]{2,63}$"
          },
          "uniqueItems": true
        },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "owner": { "type": "string", "minLength": 1 },
        "risk": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        }
      }
    },
    "extraFrontmatterValue": {
      "description": "Scalar or string-list only; no nested objects or heterogeneous arrays.",
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "maxItems": 64
        }
      ]
    },
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^V-[0-9]{3}$" },
        "severity": { "type": "string", "enum": ["error", "warning"] },
        "message": { "type": "string", "minLength": 1 },
        "path": { "type": "string" }
      }
    }
  }
}
