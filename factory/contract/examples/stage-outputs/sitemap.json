        "transition-funding-request"
      ]
    },
    {
      "id": "internal-home",
      "title": "Home",
      "path": "/",
      "page_type": "landing",
      "audience": "staff",
      "view_type": "private-authenticated",
      "requires_auth": false
    },
    {
      "id": "internal-login",
      "title": "Sign In",
      "path": "/login",
      "page_type": "login",
      "audience": "staff",
      "view_type": "public",
      "requires_auth": false
    },
    {
      "id": "internal-profile",
      "title": "My Profile",
      "path": "/profile",
      "page_type": "profile",
      "audience": "staff",
      "view_type": "private-authenticated",
