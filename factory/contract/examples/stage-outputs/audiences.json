{
  "audiences": [
    {
      "name": "citizen",
      "description": "External users from women's shelter organizations who apply for provincial funding through their Alberta.ca Account.",
      "auth_method": "saml",
      "auth_provider": "alberta-ca-account",
      "roles": [
        {
          "role_code": "applicant",
          "display_name": "Shelter Organization Applicant",
          "description": "Shelter staff who create and submit funding requests on behalf of their organization",
          "permissions": [
            "funding-request:create",
            "funding-request:read-own",
            "funding-request:update-own",
            "funding-request:submit",
            "program:write-own",
            "budget:write-own",
            "document:upload-own"
          ]
        }
      ]
    },
    {
      "name": "staff",
      "description": "Internal CFS staff who review, assess, and approve funding requests through the Government of Alberta Entra ID.",
      "auth_method": "oidc",
      "auth_provider": "entra-id",
      "roles": [
        {
          "role_code": "cfs-analyst",
          "display_name": "CFS Funding Analyst",
          "description": "Reviews and scores funding requests using filter analysis and community needs data",
          "permissions": [
            "funding-request:read",
            "assessment:write",
            "assessment:finalize",
            "community-data:read"
          ]
        },
        {
          "role_code": "cfs-manager",
          "display_name": "CFS Program Manager",
          "description": "Reviews analyst assessments and makes preliminary funding decisions",
          "permissions": [
            "funding-request:read",
            "funding-request:transition",
            "assessment:read",
            "decision:write-preliminary",
            "audit:read",
            "community-data:read"
          ]
        },
        {
          "role_code": "cfs-leadership",
          "display_name": "CFS Leadership",
          "description": "Senior leadership who recommend or advance funding decisions",
          "permissions": [
            "funding-request:read",
            "assessment:read",
            "decision:write-ministerial",
            "audit:read"
          ]
        },
        {
          "role_code": "minister-office",
          "display_name": "Minister's Office",
          "description": "Final approval authority for funding requests",
          "permissions": [
            "funding-request:read",
            "decision:write-final",
            "audit:read"
          ]
        },
        {
          "role_code": "system-admin",
          "display_name": "System Administrator",
          "description": "Manages users, roles, and system configuration",
          "permissions": [
            "user:manage",
            "role:manage",
            "audit:read",
            "integration:manage",
            "funding-request:read"
          ]
        }
      ]
    }
  ]
}
