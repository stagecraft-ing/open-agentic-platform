{
  "audiences": [
    {
      "name": "citizen",
      "description": "External users from community development organizations who apply for regional funding through their Enterprise SSO account.",
      "auth_method": "saml",
      "auth_provider": "enterprise-sso",
      "roles": [
        {
          "role_code": "applicant",
          "display_name": "Grant Organization Applicant",
          "description": "Organization staff who create and submit funding requests on behalf of their organization",
          "permissions": [
            "funding-request:create",
            "funding-request:read-own",
            "funding-request:update-own",
            "funding-request:submit",
            "program:write-own",
            "budget:write-own",
            "document:upload-own"
          ]
        }
      ]
    },
    {
      "name": "staff",
      "description": "Internal Division staff who review, assess, and approve funding requests through the Cascadia Regional Authority Entra ID.",
      "auth_method": "oidc",
      "auth_provider": "entra-id",
      "roles": [
        {
          "role_code": "grant-analyst",
          "display_name": "Division Funding Analyst",
          "description": "Reviews and scores funding requests using filter analysis and community needs data",
          "permissions": [
            "funding-request:read",
            "assessment:write",
            "assessment:finalize",
            "community-data:read"
          ]
        },
        {
          "role_code": "grant-manager",
          "display_name": "Division Program Manager",
          "description": "Reviews analyst assessments and makes preliminary funding decisions",
          "permissions": [
            "funding-request:read",
            "funding-request:transition",
            "assessment:read",
            "decision:write-preliminary",
            "audit:read",
            "community-data:read"
          ]
        },
        {
          "role_code": "division-leadership",
          "display_name": "Division Leadership",
          "description": "Senior leadership who recommend or advance funding decisions",
          "permissions": [
            "funding-request:read",
            "assessment:read",
            "decision:write-executive",
            "audit:read"
          ]
        },
        {
          "role_code": "executive-office",
          "display_name": "Executive Office",
          "description": "Final approval authority for funding requests",
          "permissions": [
            "funding-request:read",
            "decision:write-final",
            "audit:read"
          ]
        },
        {
          "role_code": "system-admin",
          "display_name": "System Administrator",
          "description": "Manages users, roles, and system configuration",
          "permissions": [
            "user:manage",
            "role:manage",
            "audit:read",
            "integration:manage",
            "funding-request:read"
          ]
        }
      ]
    }
  ]
}
