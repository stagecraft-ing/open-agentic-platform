{
  "$comment": "Variant baseline: public portal with authenticated applicant area. Equivalent to goa-software-factory's sitemap-template-public-authenticated.json. Combines public pages (landing, about, privacy) with an authenticated applicant workspace (dashboard, application form). Use when the derived variant is single-public but Stage 2 finds authenticated citizen journeys.",
  "variant": "single-public",
  "pages": [
    {
      "id": "public-home",
      "title": "Home",
      "path": "/",
      "page_type": "landing",
      "audience": "citizen",
      "view_type": "public",
      "requires_auth": false,
      "nav": { "section": "main", "order": 1 }
    },
    {
      "id": "public-about",
      "title": "About",
      "path": "/about",
      "page_type": "information",
      "audience": "citizen",
      "view_type": "public",
      "requires_auth": false,
      "nav": { "section": "main", "order": 2 }
    },
    {
      "id": "public-login",
      "title": "Sign In",
      "path": "/sign-in",
      "page_type": "login",
      "audience": "citizen",
      "view_type": "public",
      "requires_auth": false
    },
    {
      "id": "applicant-dashboard",
      "title": "My Applications",
      "path": "/dashboard",
      "page_type": "dashboard",
      "audience": "citizen",
      "view_type": "public-authenticated",
      "requires_auth": true,
      "required_roles": ["applicant"],
      "data_sources": [
        { "operation_id": "list-applications", "trigger": "on-load" }
      ],
      "nav": { "section": "applicant-main", "order": 1 }
    },
    {
      "id": "applicant-application-list",
      "title": "Applications",
      "path": "/applications",
      "page_type": "list",
      "audience": "citizen",
      "view_type": "public-authenticated",
      "requires_auth": true,
      "required_roles": ["applicant"],
      "data_sources": [
        { "operation_id": "list-applications", "trigger": "on-load" }
      ],
      "nav": { "section": "applicant-main", "order": 2 }
    },
    {
      "id": "applicant-application-detail",
      "title": "Application",
      "path": "/applications/:id",
      "page_type": "detail",
      "audience": "citizen",
      "view_type": "public-authenticated",
      "requires_auth": true,
      "required_roles": ["applicant"],
      "data_sources": [
        { "operation_id": "get-application", "trigger": "on-load" }
      ]
    },
    {
      "id": "applicant-application-form",
      "title": "Application",
      "path": "/applications/new",
      "page_type": "form",
      "audience": "citizen",
      "view_type": "public-authenticated",
      "requires_auth": true,
      "required_roles": ["applicant"],
      "data_sources": [
        { "operation_id": "create-application", "trigger": "on-submit" }
      ]
    },
    {
      "id": "applicant-profile",
      "title": "My Profile",
      "path": "/profile",
      "page_type": "profile",
      "audience": "citizen",
      "view_type": "public-authenticated",
      "requires_auth": true,
      "required_roles": ["applicant"],
      "nav": { "section": "applicant-user", "order": 1 }
    },
    {
      "id": "public-privacy",
      "title": "Privacy",
      "path": "/privacy",
      "page_type": "information",
      "audience": "citizen",
      "view_type": "public",
      "requires_auth": false,
      "nav": { "section": "footer", "order": 1 }
    },
    {
      "id": "public-accessibility",
      "title": "Accessibility",
      "path": "/accessibility",
      "page_type": "information",
      "audience": "citizen",
      "view_type": "public",
      "requires_auth": false,
      "nav": { "section": "footer", "order": 2 }
    }
  ],
  "nav": [
    {
      "section": "main",
      "audience": "citizen",
      "label": "Main",
      "pages": ["public-home", "public-about"]
    },
    {
      "section": "applicant-main",
      "audience": "citizen",
      "label": "My Account",
      "pages": ["applicant-dashboard", "applicant-application-list"]
    },
    {
      "section": "applicant-user",
      "audience": "citizen",
      "label": "User",
      "pages": ["applicant-profile"]
    },
    {
      "section": "footer",
      "audience": "citizen",
      "label": "Footer",
      "pages": ["public-privacy", "public-accessibility"]
    }
  ]
}
