{
  "name": "@opc/agent-frontmatter",
  "version": "0.1.0",
  "description": "YAML frontmatter parser for OAP agent and skill markdown definitions (spec 054)",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./linter": "./src/linter.ts",
    "./lint-cli": "./src/lint-cli.ts"
  },
  "bin": {
    "agent-frontmatter-lint": "./dist/lint-cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint:definitions": "node ./dist/lint-cli.js"
  },
  "dependencies": {
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "oap": {
    "spec": "054-agent-frontmatter-schema"
  }
}
