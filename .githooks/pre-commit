#!/usr/bin/env bash
# Opt-in pre-commit hook: refuses commits when the codebase-index has
# drifted relative to current inputs.
#
# Enable in this clone:
#   git config core.hooksPath .githooks
#
# Disable:
#   git config --unset core.hooksPath
#
# Why this exists
# ---------------
# The indexer's content hash covers more than spec.md edits — see
# `tools/codebase-indexer/src/lib.rs::collect_input_files`. Inputs are:
#   Cargo.toml (workspace + each crate/tool), package.json,
#   pnpm-workspace.yaml, specs/*/spec.md, factory/adapters/*/manifest.yaml,
#   factory/process/stages/*, .claude/{agents,commands,rules}/**/*.md,
#   standards/schemas/**/*.{json,yaml,yml}, .github/workflows/*.yml.
# Most non-trivial PRs touch at least one of these and need a fresh
# build/codebase-index/index.json in the diff. The CI staleness check
# fails after merge attempts otherwise; this hook moves the failure to
# the earliest possible point.
#
# Behaviour: read-only — never mutates the working tree or staging area.
# If the index is stale the commit is refused with a one-line fix.
# Bypass for emergencies: `git commit --no-verify`.

set -eu

INDEXER=tools/codebase-indexer/target/release/codebase-indexer

if [ ! -x "$INDEXER" ]; then
  cat >&2 <<'EOF'
[pre-commit] codebase-indexer binary not built.
            Run `make setup` (one-time) or `make index` to build it.
            To bypass for this commit only: git commit --no-verify
EOF
  exit 1
fi

if ! "$INDEXER" check >/dev/null 2>&1; then
  cat >&2 <<'EOF'
[pre-commit] codebase-index is stale relative to current inputs.

  The indexer hashes Cargo.toml, package.json, pnpm-workspace.yaml,
  specs/*/spec.md, standards/schemas/**/*.{json,yaml,yml},
  .claude/{agents,commands,rules}/*.md, and .github/workflows/*.yml —
  at least one of these changed and the
  committed build/codebase-index/index.json no longer matches.

  Fix:
    make pr-prep
    git add build/codebase-index/index.json

  Bypass (NOT recommended — CI will fail):
    git commit --no-verify
EOF
  exit 1
fi
